# =============================================================================
# Micah web — local dev: copy to `micah-web/.env` or `.env.local` (Next.js loads both).
# Production: set the same *variable names* in Vercel → Project → Settings → Environment
# Variables (never commit real secrets; GitHub holds code + this template only).
# =============================================================================

# --- Persona / BookOS branding (runtime prompt interpolation = {{agency_name}} / {{service_area}}) ---
MICAH_AGENCY_NAME=Directive OS
# MICAH_SERVICE_AREA=Western Sydney   # optional — spoken/prompt “patch”; defaults to “our local area” if unset
# MICAH_PRINCIPAL_NAME=...   # optional legacy

# -----------------------------------------------------------------------------
# ElevenLabs + Supabase Storage (`<Play>` MP3 on /api/voice/process + /api/process)
# -----------------------------------------------------------------------------
# BRAND-STRICT POLICY: All spoken output must originate from ElevenLabs Aussie
# Micah voice (id=4Nz4vG2f9omkfcS8r4PJ) or pre-recorded static MP3 audio approved
# by Directive OS. Polly/Olivia, default Twilio system voices, or any other
# fallback are forbidden. Fallback to silence is acceptable only when all assets
# are unavailable. No other TTS system shall be present in this pipeline.
#
# Code enables ElevenLabs when: ELEVENLABS_API_KEY, SUPABASE_TTS_BUCKET, SUPABASE_SERVICE_ROLE_KEY,
# SUPABASE_URL (or NEXT_PUBLIC_SUPABASE_URL). Voice id **MICAH_ELEVENLABS_VOICE_ID** is **only**
# in `lib/elevenlabs-tts.ts` (literal `4Nz4vG2f9omkfcS8r4PJ`) — there is **no** env var for it.
# `/api/voice/incoming` may use `MICAH_GREETING_MP3_URL` for instant `<Play>` — that file MUST be
# the Aussie Micah voice; a wrong file there sounds like the wrong voice on every call.
# If EL times out or fails → TwiML plays `MICAH_FALLBACK_MP3_URL` (pre-recorded Aussie Micah).
# If THAT is also unset → silent `<Pause>` (logged loudly). Polly is never invoked.
#
# Common misconfig errors:
#   • Twilio `<Play>` 403 → bucket not public-read for anon, or wrong SUPABASE_STORAGE_PUBLIC_URL_BASE
#   • No EL audio → wrong bucket name, bad API key, or EL timeout (see ELEVENLABS_TTS_TIMEOUT_MS)
#   • Upload fails → SERVICE_ROLE key wrong or bucket does not exist / RLS blocking service role
#   • Silent calls → MICAH_FALLBACK_MP3_URL not set AND ElevenLabs failing — set the fallback MP3.

ELEVENLABS_API_KEY=
# Exact Storage bucket name (often **micah-tts**). Public URL pattern:
# https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/micah-tts/...
SUPABASE_TTS_BUCKET=

# Supabase project (required for EL upload path + optional call_logs / tenants).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_SUPABASE_URL=   # alternative to SUPABASE_URL if you already expose URL to client

# Optional ElevenLabs / Storage tuning
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Default 1500ms — on timeout, voice routes fall back to MICAH_FALLBACK_MP3_URL <Play>
# (or silent <Pause> if unset). Polly is forbidden. Raise only if EL + upload routinely need more time.
# ELEVENLABS_TTS_TIMEOUT_MS=1500
# If public file URLs use a CDN or different host than default Supabase API URL:
# SUPABASE_STORAGE_PUBLIC_URL_BASE=https://YOUR_PROJECT.supabase.co/storage/v1/object/public
#
# After deploy: GET `/api/voice/diagnostic` on your production host — confirms EL + Supabase env (no secrets).
# MICAH_SKIP_PLAY_URL_CHECK=1   # optional — skip HEAD probe on each synthesized MP3 URL
# MICAH_DEBUG_TWIML=1           # optional — log full TwiML XML in server logs (default logs length only)

# -----------------------------------------------------------------------------
# OpenAI (required for gather chat replies)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_MICAH_PROCESS_MODEL=gpt-4o-mini
# If the chat API errors, `/api/voice/process` speaks this as Micah (see `lib/micah/micah-voice-persona.ts`).
# OpenAI offline fallback is hardcoded to "I'm listening." so the post-greeting flow never repeats an opening greeting.

# -----------------------------------------------------------------------------
# Twilio (required in production for signed voice webhooks)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# MICAH_SKIP_TWILIO_SIGNATURE=1   # local only — NEVER production

# -----------------------------------------------------------------------------
# Canonical site URL (Gather `action` — Twilio POST must hit your production host)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://micah.directiveos.com.au

# -----------------------------------------------------------------------------
# Inbound line persona (Twilio `To` — demo vs main Directive OS reception rules)
# -----------------------------------------------------------------------------
# Defaults match +61259506382 (02 5950 6382 demo) and +61258504038 (02 5850 4038 main).
# MICAH_DEMO_RECEPTION_NUMBER=+61259506382
# MICAH_MAIN_DIRECTIVE_NUMBER=+61258504038

# -----------------------------------------------------------------------------
# OpenAI Realtime bridge (Fly / Railway — not on Vercel serverless)
# -----------------------------------------------------------------------------
# MICAH_VOICE_ENGINE=realtime
# MICAH_MEDIA_STREAM_WSS_URL=wss://your-bridge-host.example/twilio
# MICAH_BRIDGE_SECRET=
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# --- Static Aussie Micah MP3 assets (BRAND POLICY: required to avoid silent fallback) ---
#
# MICAH_GREETING_MP3_URL — pre-recorded Aussie Micah opening greeting played
# instantly by /api/voice/incoming via <Play>. The greeting is the same string
# every call, so a one-time render is both 100% Aussie Micah voice AND zero
# synthesis latency at pickup.
# MICAH_GREETING_MP3_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/micah-tts/greeting.mp3
#
# MICAH_FALLBACK_MP3_URL — pre-recorded Aussie Micah "Sorry, I'm having trouble
# right now. Please try again later." played via <Play> whenever ElevenLabs
# synthesis fails. Without this set, EL outages produce silent <Pause> (the only
# acceptable last resort under brand policy — Polly is forbidden).
# Generate with the snippet in README under "Aussie Micah fallback asset" and
# upload to your public micah-tts bucket.
# MICAH_FALLBACK_MP3_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/micah-tts/micah-fallback.mp3
#
# Optional script overrides (text only — never spoken directly anymore; the
# matching MP3 plays in their place). Kept for log/diagnostic context.
# MICAH_GATHER_GREETING=
# MICAH_GATHER_TIMEOUT_SAY=
# MICAH_REALTIME_PRECONNECT_SAY=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM="Micah <leads@directiveos.com.au>"
# MICAH_TRANSCRIPT_DEFAULT_TO=leads@directiveos.com.au
# MICAH_RESEND_TEST_TO=
# MICAH_TRANSCRIPT_API_SECRET=
# MICAH_VOICE_NOTIFY_EMAIL=

# --- Command Centre handoff (optional) ---
# Production Micah Voice remains micah-web + ElevenLabs voice id 4Nz4vG2f9omkfcS8r4PJ.
# When set, /api/voice/call-status POSTs completed-call summaries to Command Centre.
# COMMAND_CENTRE_WEBHOOK_URL=
# COMMAND_CENTRE_WEBHOOK_SECRET=

# --- Tenants / leads ---
# TENANT_INBOUND_COLUMN=inbound_number

# --- Legacy / optional ---
# MICAH_FALLBACK_AGENCY_NAME=
# MICAH_FALLBACK_CLIENT_EMAIL=
# TWILIO_AUTH_BY_ACCOUNT_JSON={"AC...":"token"}
# OPENAI_TTS_MODEL=tts-1-hd
# MICAH_STT_MULTILINGUAL=
# OPENAI_TRANSCRIBE_LANGUAGE=en
# MICAH_TWIML_MODE=gather
