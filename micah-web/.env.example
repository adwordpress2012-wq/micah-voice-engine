# Required
OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=

# Twilio — required to download recordings for Whisper (MICAH_TWIML_MODE=record); avoids HTTP 401.
# Token must be for the same Twilio account as these SIDs. AccountSid is also sent on webhooks if SID omitted.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Production site (live): canonical URL for callbacks when Host inference isn’t used
NEXT_PUBLIC_APP_URL=https://micah.directiveos.com.au

# Map inbound DID → tenant (column name on tenants table, default inbound_number)
# TENANT_INBOUND_COLUMN=inbound_number

# Resend: email transcript when call completes (see /api/voice/call-status + Twilio Status Callback)
RESEND_API_KEY=
RESEND_FROM="Micah <leads@directiveos.com.au>"

# Public bucket for TTS MP3 (ElevenLabs → Twilio <Play>). Create in Supabase → Storage → public read.
# SUPABASE_TTS_BUCKET=micah-tts

# ElevenLabs text-to-speech (Micah voice playback). Falls back to Polly if unset or on error.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# STT: omit language by default (multilingual). Set MICAH_STT_MULTILINGUAL=false to pin English.
# MICAH_STT_MULTILINGUAL=
# OPENAI_TRANSCRIBE_LANGUAGE=en

# Conversational voice: gather (default) = speech loop; record = Whisper on recordings
# MICAH_TWIML_MODE=gather

# Polly fallback when ElevenLabs / bucket unavailable (sweet AU young female)
# MICAH_POLLY_VOICE=Polly.Olivia

# Optional
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# MICAH_TWIML_MODE=record
