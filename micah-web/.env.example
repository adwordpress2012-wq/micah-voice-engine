# Required (Command Centre Portal / Supabase project)
OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_URL=

# Optional: public Storage URL prefix if the project uses a custom CDN or you must pin the new project host explicitly.
# Format: https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public (no trailing slash)
# SUPABASE_STORAGE_PUBLIC_URL_BASE=

# Twilio — recording fetch uses webhook AccountSid first, then TWILIO_ACCOUNT_SID, with Auth Token for that account.
# Multi-account: JSON map of AccountSid → auth token (from Twilio Console for each subaccount).
# TWILIO_AUTH_BY_ACCOUNT_JSON={"ACaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa":"token_a","ACbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb":"token_b"}
TWILIO_ACCOUNT_SID=
# Same Auth Token validates Twilio Voice POSTs (X-Twilio-Signature) for /api/voice/incoming + /api/voice/process.
TWILIO_AUTH_TOKEN=
# MICAH_SKIP_TWILIO_SIGNATURE=1   # local debug only — disables signature checks; never set in production.

# --- OpenAI Realtime + Twilio Media Streams (deploy `micah-realtime-bridge` separately — not on Vercel serverless)
# MICAH_VOICE_ENGINE=realtime
# MICAH_MEDIA_STREAM_WSS_URL=wss://your-bridge-host.example/twilio
# MICAH_BRIDGE_SECRET=random-long-secret   # REQUIRED for realtime auth — same value on Fly (`fly secrets`) and Vercel Production; redeploy Vercel after changes
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Production site (live): canonical URL for callbacks when Host inference isn’t used
NEXT_PUBLIC_APP_URL=https://micah.directiveos.com.au

# Demo number (E.164). When dialled, Micah persona unlocks real-estate topics.
# Main number always blocks real estate; only the demo line allows it.
# MICAH_DEMO_NUMBER=+61259506382

# Map inbound DID → tenant (column name on tenants table, default inbound_number)
# TENANT_INBOUND_COLUMN=inbound_number

# Resend: email transcript when call completes (see /api/voice/call-status + Twilio Status Callback)
RESEND_API_KEY=
RESEND_FROM="Micah <leads@directiveos.com.au>"
# Optional: email each /api/voice/process turn (with transcript + reply). Requires RESEND_API_KEY.
# MICAH_VOICE_NOTIFY_EMAIL=you@yourdomain.com.au

# TTS MP3 bucket — MUST allow anonymous/public read or Twilio <Play> gets 403 → generic application error on the call.
# Supabase: bucket → Policies → public SELECT for anon, or use a signed URL flow (not implemented here).
# SUPABASE_TTS_BUCKET=micah-tts

# ElevenLabs text-to-speech (Micah voice playback). Falls back to Polly.Olivia if unset or on error.
ELEVENLABS_API_KEY=
# Voice: accepts ELEVENLABS_VOICE_ID or AUSSIE_MICAH; hard default = 4Nz4vG2f9omkfcS8r4PJ (Aussie Micah)
ELEVENLABS_VOICE_ID=4Nz4vG2f9omkfcS8r4PJ
# AUSSIE_MICAH=4Nz4vG2f9omkfcS8r4PJ   # alias — either name works
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# STT: omit language by default (multilingual). Set MICAH_STT_MULTILINGUAL=false to pin English.
# MICAH_STT_MULTILINGUAL=
# OPENAI_TRANSCRIBE_LANGUAGE=en

# Conversational voice: gather (default) = speech loop; record = Whisper on recordings
# MICAH_TWIML_MODE=gather

# GREETING audio for /api/voice/incoming. Optional. If set, the call's opening
# greeting plays this MP3 (a pre-recorded Aussie Micah "G'day! You've reached..."
# at the URL you provide). If unset, the greeting falls back to instant
# <Say voice="Polly.Olivia" language="en-AU"> so there's never silence at pickup.
# (We never await ElevenLabs for the greeting — synthesis takes 1–3s and would
# create perceptible silence.)
# MICAH_GREETING_MP3_URL=https://your-supabase.example/storage/v1/object/public/micah-tts/static/aussie-micah-greeting.mp3

# AI-REPLY voice fallback chain (used by /api/voice/process and /api/process):
#   1. ElevenLabs Aussie Micah voice 4Nz4vG2f9omkfcS8r4PJ (hard-coded, env-overridable)
#   2. MICAH_FALLBACK_MP3_URL (optional, pre-recorded Aussie Micah apology MP3)
#   3. <Say voice="Polly.Olivia" language="en-AU"> (AWS Neural female AU — last resort)
# Polly.Olivia is the same gender/accent as Aussie Micah, just a different TTS engine.
# Polly.Olivia is hardcoded in lib/micah/voice-output.ts so it can never be overridden
# to a male voice. The legacy MICAH_POLLY_VOICE env var is NOT read anywhere.
# MICAH_FALLBACK_MP3_URL=https://your-supabase.example/storage/v1/object/public/micah-tts/static/aussie-micah-apology.mp3

# /api/process (simpler multi-tenant webhook — set Voice URL to https://your-domain/api/process)
# OPENAI_MICAH_PROCESS_MODEL=gpt-4o-mini
# MICAH_FALLBACK_AGENCY_NAME=our office
# MICAH_FALLBACK_CLIENT_EMAIL=

# Optional
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# MICAH_TWIML_MODE=record
