# Required
OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=

# Twilio recording fetch (recommended when RecordingUrl needs auth)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Public URL of this deployment (Vercel: set in dashboard or use VERCEL_URL at runtime)
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Map inbound DID → tenant (column name on tenants table, default inbound_number)
# TENANT_INBOUND_COLUMN=inbound_number

# Resend: email transcript when call completes (see /api/voice/call-status + Twilio Status Callback)
RESEND_API_KEY=
RESEND_FROM="Micah <onboarding@resend.dev>"

# Optional
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# MICAH_TWIML_MODE=record
# MICAH_TWIML_MODE=gather
