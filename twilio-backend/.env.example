# Required
OPENAI_API_KEY=

# Voice (OpenAI Realtime)
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
# OPENAI_REALTIME_VOICE=cedar
# MICAH_SYSTEM_PROMPT=You are Micah, ...

# Optional: override auto-detected Twilio Stream URL (must match your public HTTPS host)
# PUBLIC_BASE_URL=https://your-service.a.run.app

# SMS webhook still uses:
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_SYSTEM_PROMPT=

# After each call — JSON body: { callSid, callerId, transcript[], endedAt }
COMMAND_CENTRE_WEBHOOK_URL=
# COMMAND_CENTRE_WEBHOOK_SECRET=

PORT=8080
